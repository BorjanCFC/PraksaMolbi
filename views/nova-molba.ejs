<!DOCTYPE html>
<html lang="mk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Систем за електронско поднесување молби</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="animated-bg"></div>
  <div class="header-wrap">
    <div class="header-top"></div>
    <header class="header">
      <div class="header-container">
        <a href="/dashboard" class="logo">
          <img src="/images/logo-feit-header.png" alt="УКИМ — ФЕИТ" class="header-logo-wide">
        </a>
        <nav>
          <span class="nav-user"><%= studentName %></span>
          <a href="/logout" class="nav-link btn-logout">Одјава</a>
        </nav>
      </div>
    </header>
  </div>

  <main class="container">
    <div class="form-card">
      <h2>Нова молба</h2>
      <p class="subtitle">Пополнете го формуларот за да испратите молба до студентска служба</p>

      <% if (error && error.length > 0) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/dashboard/nova-molba" method="POST">
        <div class="form-group">
          <label for="description">Опис на молбата</label>
          <textarea id="description" name="description" rows="6" placeholder="Внесете детален опис на вашата молба..." required></textarea>
        </div>

        <div class="form-actions">
          <a href="/dashboard" class="btn btn-secondary">Откажи</a>
          <button type="submit" class="btn btn-primary">Испрати молба</button>
        </div>
      </form>
    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-links">
        <a href="https://feit.ukim.edu.mk" target="_blank">ФЕИТ</a>
        <a href="https://www.iknow.ukim.mk" target="_blank">iKnow</a>
        <a href="https://e-kursevi.feit.ukim.edu.mk" target="_blank">е-Курсеви</a>
        <a href="mailto:studentska@feit.ukim.edu.mk">Контакт</a>
      </div>
      <div class="footer-copy">
        &copy; 2026 ФЕИТ — Студентска Служба. Сите права задржани.
      </div>
    </div>
  </footer>
</body>
</html>
