<!DOCTYPE html>
<html lang="mk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Систем за електронско поднесување молби</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/images/feitLogoBrowser.png">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .login-tabs {
      display: flex;
      gap: 0;
      margin-bottom: 30px;
      border-bottom: 2px solid #e0e0e0;
    }

    .login-tab-btn {
      flex: 1;
      padding: 12px 20px;
      border: none;
      background: transparent;
      color: #666;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
    }

    .login-tab-btn:hover {
      color: #0066cc;
      background-color: rgba(0, 102, 204, 0.05);
    }

    .login-tab-btn.active {
      color: #0066cc;
      border-bottom-color: #0066cc;
    }

    .login-tab-content {
      display: none;
      animation: fadeIn 0.3s ease;
    }

    .login-tab-content.active {
      display: block;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(-5px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .tab-description {
      text-align: center;
      color: #666;
      margin-bottom: 25px;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="login-wrapper">
    <div class="floating-shapes">
      <span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span>
    </div>

    <div class="lightning-bolts">
      <div class="lightning-bolt"><svg viewBox="0 0 40 80" fill="none"><polygon points="22,0 8,35 18,35 10,80 35,30 24,30 32,0" fill="rgba(255,220,100,0.7)"/></svg></div>
      <div class="lightning-bolt"><svg viewBox="0 0 40 80" fill="none"><polygon points="22,0 8,35 18,35 10,80 35,30 24,30 32,0" fill="rgba(180,210,255,0.6)"/></svg></div>
      <div class="lightning-bolt"><svg viewBox="0 0 40 80" fill="none"><polygon points="22,0 8,35 18,35 10,80 35,30 24,30 32,0" fill="rgba(255,220,100,0.5)"/></svg></div>
      <div class="lightning-bolt"><svg viewBox="0 0 40 80" fill="none"><polygon points="22,0 8,35 18,35 10,80 35,30 24,30 32,0" fill="rgba(180,210,255,0.5)"/></svg></div>
      <div class="lightning-bolt"><svg viewBox="0 0 40 80" fill="none"><polygon points="22,0 8,35 18,35 10,80 35,30 24,30 32,0" fill="rgba(255,220,100,0.6)"/></svg></div>
      <div class="lightning-bolt"><svg viewBox="0 0 40 80" fill="none"><polygon points="22,0 8,35 18,35 10,80 35,30 24,30 32,0" fill="rgba(180,210,255,0.4)"/></svg></div>
    </div>

    <div class="login-card">
      <div class="login-header">
        <img src="/images/logo-feit-header.png" alt="УКИМ — ФЕИТ" class="login-logo-wide">
        <div class="login-divider"></div>
        <h2>Систем за електронско поднесување молби</h2>
      </div>

      <% if (error && error.length > 0) { %>
        <div class="alert alert-error">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <% if (success && success.length > 0) { %>
        <div class="alert alert-success">
          ✅ <%= success %>
        </div>
      <% } %>

      <!-- STUDENT LOGIN -->
      <div class="student-login">
        <div class="tab-description">
          <p class="welcome-title">Добредојдовте!</p>
          <p class="welcome-subtitle">Најавете се со вашиот студентски Microsoft акаунт</p>
        </div>
        <% if (entraEnabled) { %>
          <a href="/auth/microsoft" class="btn btn-primary btn-full">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 8px;">
              <path d="M11.4 24H0V12.6h11.4V24zM24 24H12.6V12.6H24V24zM11.4 11.4H0V0h11.4v11.4zm12.6 0H12.6V0H24v11.4z"/>
            </svg>
            Најава со Microsoft
          </a>

          <div style="margin-top: 14px; text-align: center;">
            <p style="font-size: 13px; color: #5a6a7a; margin-bottom: 10px;">
              Немате студентски account? Креирајте го овде.
            </p>
            <a
              href="https://signup.microsoft.com/get-started/signup?sku=018f6278-19f3-455c-8940-df2e59e59ca7&products=018f6278-19f3-455c-8940-df2e59e59ca7&ali=1&culture=en-us&country=us"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-full"
              style="display: inline-block;"
            >
              Креирај account / Регистрирај се
            </a>
          </div>
        <% } else { %>
          <div class="alert alert-error">
            ⚠️ Microsoft Entra не е конфигуриран во апликацијата.
          </div>
        <% } %>
      </div>

      <div class="login-footer">
        <a href="https://feit.ukim.edu.mk">feit.ukim.edu.mk</a>
        <span class="login-footer-sep">|</span>
        <a href="https://www.iknow.ukim.mk">iknow.ukim.mk</a>
      </div>
    </div>
  </div>
</body>
</html>
