<!DOCTYPE html>
<html lang="mk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Систем за електронско поднесување молби</title>
  <link rel="icon" type="image/png" sizes="64x64" href="/images/feitLogoBrowser.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header', { viewer, isImpersonating }) %>

  <main class="container">
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (!isStudent) { %>
      <div class="dashboard-header">
        <div>
          <h2>Сите молби</h2>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number"><%= stats.vkupno %></div>
          <div class="stat-label">Вкупно молби</div>
        </div>
        <div class="stat-card stat-proces">
          <div class="stat-number"><%= stats.voProces %></div>
          <div class="stat-label">Во процес</div>
        </div>
        <div class="stat-card stat-odobrena">
          <div class="stat-number"><%= stats.odobreni %></div>
          <div class="stat-label">Одобрени</div>
        </div>
        <div class="stat-card stat-odbiena">
          <div class="stat-number"><%= stats.odbieni %></div>
          <div class="stat-label">Одбиени</div>
        </div>
      </div>

      <% if (isGlobalAdmin) { %>
        <div class="admin-action-card" style="margin-bottom: 1.5rem; max-width: 100%;">
          <h3>Додели улога</h3>
          <form action="/dashboard/assign-role" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="assignEmail">Email</label>
                <input id="assignEmail" name="email" type="email" placeholder="Внеси валидна email адреса" required>
              </div>
              <div class="form-group">
                <label for="assignRole">Улога</label>
                <select id="assignRole" name="role" class="form-select" required>
                  <option value="admin">Админ</option>
                  <option value="studentska_sluzhba">Студентска Служба</option>
                  <option value="prodekan">Продекан</option>
                  <option value="arhiva">Архива</option>
                </select>
              </div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-admin">Зачувај улога</button>
            </div>
          </form>
        </div>
      <% } %>

      <div class="filter-bar">
        <div class="filter-group">
          <label for="statusFilter">Статус:</label>
          <select id="statusFilter" class="form-select filter-select">
            <option value="site" <%= currentStatus === 'site' ? 'selected' : '' %>>Сите</option>
            <option value="Во процес" <%= currentStatus === 'Во процес' ? 'selected' : '' %>>Во процес</option>
            <option value="Одобрена" <%= currentStatus === 'Одобрена' ? 'selected' : '' %>>Одобрена</option>
            <option value="Одбиена" <%= currentStatus === 'Одбиена' ? 'selected' : '' %>>Одбиена</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="semestarFilter">Семестар:</label>
          <select id="semestarFilter" class="form-select filter-select">
            <option value="site" <%= currentSemestar === 'site' ? 'selected' : '' %>>Сите</option>
            <option value="Зимски" <%= currentSemestar === 'Зимски' ? 'selected' : '' %>>Зимски</option>
            <option value="Летен" <%= currentSemestar === 'Летен' ? 'selected' : '' %>>Летен</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="fromDate">Од датум:</label>
          <input id="fromDate" class="form-select filter-select" type="date" value="<%= currentFromDate %>">
        </div>
        <div class="filter-group">
          <label for="toDate">До датум:</label>
          <input id="toDate" class="form-select filter-select" type="date" value="<%= currentToDate %>">
        </div>
        <button type="button" class="btn btn-secondary btn-small" onclick="clearFilters()">Исчисти</button>
      </div>

      <script>
        document.getElementById('statusFilter').addEventListener('change', applyFilters);
        document.getElementById('semestarFilter').addEventListener('change', applyFilters);
        document.getElementById('fromDate').addEventListener('change', applyFilters);
        document.getElementById('toDate').addEventListener('change', applyFilters);

        function applyFilters() {
          const status = document.getElementById('statusFilter').value;
          const semestar = document.getElementById('semestarFilter').value;
          const fromDate = document.getElementById('fromDate').value;
          const toDate = document.getElementById('toDate').value;
          window.location.href = '/dashboard?status=' + encodeURIComponent(status) + '&semestar=' + encodeURIComponent(semestar) + '&fromDate=' + encodeURIComponent(fromDate) + '&toDate=' + encodeURIComponent(toDate);
        }

        function clearFilters() {
          window.location.href = '/dashboard?status=site&semestar=site&fromDate=&toDate=';
        }
      </script>

      <% if (molbi.length === 0) { %>
        <div class="empty-state">
          <h3>Нема молби за избраните филтри</h3>
          <p>Променете филтер или почекајте нови поднесувања.</p>
        </div>
      <% } else { %>
        <div class="table-wrapper">
          <table class="molbi-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Студент</th>
                <th>Бр. индекс</th>
                <th>Наслов</th>
                <th>Семестар / учебна година</th>
                <th>Датум</th>
                <th>Статус</th>
                <th>Акции</th>
              </tr>
            </thead>
            <tbody>
              <% molbi.forEach((molba) => { %>
                <tr>
                  <td><%= molba.molbaId %></td>
                  <td><%= convertNameToCyrillic(molba.student.ime) %> <%= convertNameToCyrillic(molba.student.prezime) %></td>
                  <td><%= molba.student.brIndeks || (molba.student.studentProfile ? molba.student.studentProfile.brIndeks : null) || '-' %></td>
                  <td class="desc-cell"><%= (molba.naslov || 'Без наслов').substring(0, 70) %><%= (molba.naslov || '').length > 70 ? '...' : '' %></td>
                  <td><%= molba.semestar %> / <%= molba.ucebnaGodina || '-' %></td>
                  <td><%= molba.datum %></td>
                  <td>
                    <span class="status-badge status-<%= molba.status === 'Во процес' ? 'proces' : molba.status === 'Одобрена' ? 'odobrena' : 'odbiena' %>">
                      <%= molba.status %>
                    </span>
                  </td>
                  <td>
                    <a href="/dashboard/molba/<%= molba.molbaId %>" class="btn btn-small">Детали</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

    <% } else { %>
      <div class="dashboard-header">
        <div>
          <h2>Мои молби</h2>
        </div>
        <a href="/dashboard/nova-molba" class="btn btn-primary">+ Нова молба</a>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number"><%= siteMolbi.length %></div>
          <div class="stat-label">Вкупно молби</div>
        </div>
        <div class="stat-card stat-proces">
          <div class="stat-number"><%= siteMolbi.filter(m => m.status === 'Во процес').length %></div>
          <div class="stat-label">Во процес</div>
        </div>
        <div class="stat-card stat-odobrena">
          <div class="stat-number"><%= siteMolbi.filter(m => m.status === 'Одобрена').length %></div>
          <div class="stat-label">Одобрени</div>
        </div>
        <div class="stat-card stat-odbiena">
          <div class="stat-number"><%= siteMolbi.filter(m => m.status === 'Одбиена').length %></div>
          <div class="stat-label">Одбиени</div>
        </div>
      </div>

      <div class="filter-bar">
        <div class="filter-group">
          <label for="statusFilterStudent">Статус:</label>
          <select id="statusFilterStudent" class="form-select filter-select">
            <option value="site" <%= currentStatus === 'site' ? 'selected' : '' %>>Сите</option>
            <option value="Во процес" <%= currentStatus === 'Во процес' ? 'selected' : '' %>>Во процес</option>
            <option value="Одобрена" <%= currentStatus === 'Одобрена' ? 'selected' : '' %>>Одобрена</option>
            <option value="Одбиена" <%= currentStatus === 'Одбиена' ? 'selected' : '' %>>Одбиена</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="semestarFilterStudent">Семестар:</label>
          <select id="semestarFilterStudent" class="form-select filter-select">
            <option value="site" <%= currentSemestar === 'site' ? 'selected' : '' %>>Сите</option>
            <option value="Зимски" <%= currentSemestar === 'Зимски' ? 'selected' : '' %>>Зимски</option>
            <option value="Летен" <%= currentSemestar === 'Летен' ? 'selected' : '' %>>Летен</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="fromDateStudent">Од датум:</label>
          <input id="fromDateStudent" class="form-select filter-select" type="date" value="<%= currentFromDate %>">
        </div>
        <div class="filter-group">
          <label for="toDateStudent">До датум:</label>
          <input id="toDateStudent" class="form-select filter-select" type="date" value="<%= currentToDate %>">
        </div>
        <button type="button" class="btn btn-secondary btn-small" onclick="clearStudentFilters()">Исчисти</button>
      </div>

      <script>
        document.getElementById('statusFilterStudent').addEventListener('change', applyStudentFilters);
        document.getElementById('semestarFilterStudent').addEventListener('change', applyStudentFilters);
        document.getElementById('fromDateStudent').addEventListener('change', applyStudentFilters);
        document.getElementById('toDateStudent').addEventListener('change', applyStudentFilters);

        function applyStudentFilters() {
          const status = document.getElementById('statusFilterStudent').value;
          const semestar = document.getElementById('semestarFilterStudent').value;
          const fromDate = document.getElementById('fromDateStudent').value;
          const toDate = document.getElementById('toDateStudent').value;
          window.location.href = '/dashboard?status=' + encodeURIComponent(status) + '&semestar=' + encodeURIComponent(semestar) + '&fromDate=' + encodeURIComponent(fromDate) + '&toDate=' + encodeURIComponent(toDate);
        }

        function clearStudentFilters() {
          window.location.href = '/dashboard?status=site&semestar=site&fromDate=&toDate=';
        }
      </script>

      <% if (molbi.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">📭</div>
          <h3>Немате испратено молби</h3>
          <p>Кликнете на „Нова молба“ за да испратите барање.</p>
        </div>
      <% } else { %>
        <div class="table-wrapper">
          <table class="molbi-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Наслов</th>
                <th>Семестар / учебна година</th>
                <th>Датум</th>
                <th>Статус</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% molbi.forEach((molba, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td class="desc-cell"><%= (molba.naslov || 'Без наслов').substring(0, 80) %><%= (molba.naslov || '').length > 80 ? '...' : '' %></td>
                  <td><%= molba.semestar %> / <%= molba.ucebnaGodina || '-' %></td>
                  <td><%= molba.datum %></td>
                  <td>
                    <span class="status-badge status-<%= molba.status === 'Во процес' ? 'proces' : molba.status === 'Одобрена' ? 'odobrena' : 'odbiena' %>">
                      <%= molba.status %>
                    </span>
                  </td>
                  <td>
                    <a href="/dashboard/molba/<%= molba.molbaId %>" class="btn btn-small">Детали</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
