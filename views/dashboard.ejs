<!DOCTYPE html>
<html lang="mk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Систем за електронско поднесување молби</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="animated-bg"></div>
  <div class="header-wrap">
    <div class="header-top"></div>
    <header class="header">
      <div class="header-container">
        <a href="/dashboard" class="logo">
          <img src="/images/logo-feit-header.png" alt="УКИМ — ФЕИТ" class="header-logo-wide">
        </a>
        <nav>
          <span class="nav-user"><%= student.ime %> <%= student.prezime %> (<%= student.brIndeks %>)</span>
          <a href="/logout" class="nav-link btn-logout">Одјава</a>
        </nav>
      </div>
    </header>
  </div>

  <main class="container">
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="dashboard-header">
      <div>
        <h2>Мои молби</h2>
        <p class="subtitle">Преглед на сите испратени молби до студентска служба</p>
      </div>
      <a href="/dashboard/nova-molba" class="btn btn-primary">+ Нова молба</a>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-number"><%= siteMolbi.length %></div>
        <div class="stat-label">Вкупно молби</div>
      </div>
      <div class="stat-card stat-proces">
        <div class="stat-number"><%= siteMolbi.filter(m => m.status === 'Во процес').length %></div>
        <div class="stat-label">Во процес</div>
      </div>
      <div class="stat-card stat-odobrena">
        <div class="stat-number"><%= siteMolbi.filter(m => m.status === 'Одобрена').length %></div>
        <div class="stat-label">Одобрени</div>
      </div>
      <div class="stat-card stat-odbiena">
        <div class="stat-number"><%= siteMolbi.filter(m => m.status === 'Одбиена').length %></div>
        <div class="stat-label">Одбиени</div>
      </div>
    </div>

    <!-- Filter po status -->
    <div class="filter-bar">
      <label for="statusFilter">Филтрирај по статус:</label>
      <select id="statusFilter" class="form-select filter-select" onchange="window.location.href='/dashboard?status='+this.value">
        <option value="site" <%= currentStatus === 'site' ? 'selected' : '' %>>Сите</option>
        <option value="Во процес" <%= currentStatus === 'Во процес' ? 'selected' : '' %>>Во процес</option>
        <option value="Одобрена" <%= currentStatus === 'Одобрена' ? 'selected' : '' %>>Одобрена</option>
        <option value="Одбиена" <%= currentStatus === 'Одбиена' ? 'selected' : '' %>>Одбиена</option>
      </select>
    </div>

    <% if (molbi.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">📭</div>
        <h3>Немате испратено молби</h3>
        <p>Кликнете на "Нова молба" за да испратите молба до студентска служба.</p>
      </div>
    <% } else { %>
      <div class="table-wrapper">
        <table class="molbi-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Опис</th>
              <th>Датум</th>
              <th>Статус</th>
              <th>Акции</th>
            </tr>
          </thead>
          <tbody>
            <% molbi.forEach((molba, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td class="desc-cell"><%= molba.description.substring(0, 80) %><%= molba.description.length > 80 ? '...' : '' %></td>
                <td><%= molba.datum %></td>
                <td>
                  <span class="status-badge status-<%= molba.status === 'Во процес' ? 'proces' : molba.status === 'Одобрена' ? 'odobrena' : 'odbiena' %>">
                    <%= molba.status %>
                  </span>
                </td>
                <td>
                  <a href="/dashboard/molba/<%= molba.molbaId %>" class="btn btn-small">Детали</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-links">
        <a href="https://feit.ukim.edu.mk" target="_blank">ФЕИТ</a>
        <a href="https://www.iknow.ukim.mk" target="_blank">iKnow</a>
        <a href="https://e-kursevi.feit.ukim.edu.mk" target="_blank">е-Курсеви</a>
        <a href="mailto:studentska@feit.ukim.edu.mk">Контакт</a>
      </div>
      <div class="footer-copy">
        &copy; 2026 ФЕИТ — Студентска Служба. Сите права задржани.
      </div>
    </div>
  </footer>
</body>
</html>
