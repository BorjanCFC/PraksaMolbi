<!DOCTYPE html>
<html lang="mk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Систем за електронско поднесување молби</title>
  <link rel="icon" type="image/png" sizes="64x64" href="/images/feitLogoBrowser.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header', { viewer, isImpersonating }) %>

  <main class="container">
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="detail-card">
      <div class="detail-header">
        <h2>Молба #<%= molba.molbaId %></h2>
        <span class="status-badge status-<%= molba.status === 'Во процес' ? 'proces' : molba.status === 'Одобрена' ? 'odobrena' : 'odbiena' %>">
          <%= molba.status %>
        </span>
      </div>

      <div class="detail-info">
        <div class="detail-row">
          <strong>Студент:</strong>
          <span>
            <%= convertNameToCyrillic(molba.student.ime) %> <%= convertNameToCyrillic(molba.student.prezime) %>
            <% const studentBrIndeks = molba.student.brIndeks || (molba.student.studentProfile ? molba.student.studentProfile.brIndeks : null); %>
            <% if (studentBrIndeks) { %>
              <span style="color: #000000c1; margin-left: 1rem;">
                <%= studentBrIndeks %>
              </span>
            <% } %>
          </span>
        </div>
        <div class="detail-row">
          <strong>Email:</strong>
          <span><%= molba.student.email %></span>
        </div>
        <div class="detail-row">
          <strong>Датум на поднесување:</strong>
          <span><%= molba.datum %></span>
        </div>
        <div class="detail-row">
          <strong>Наслов:</strong>
          <span><%= molba.naslov || 'Без наслов' %></span>
        </div>
        <% const studentSmer = molba.student.smer || (molba.student.studentProfile ? molba.student.studentProfile.smer : null); %>
        <% if (studentSmer) { %>
          <div class="detail-row">
            <strong>Насока:</strong>
            <span><%= studentSmer %></span>
          </div>
        <% } %>
        <div class="detail-row">
          <strong>Семестар:</strong>
          <span><%= molba.semestar %></span>
        </div>
        <div class="detail-row">
          <strong>Учебна година:</strong>
          <span><%= molba.ucebnaGodina || 'Нема податок' %></span>
        </div>
        <div class="detail-row">
          <strong>Архивски број:</strong>
          <span><%= molba.arhivskiBroj || 'Не е внесено' %></span>
        </div>
      </div>

      <div class="detail-section">
        <h3>Опис на молбата</h3>
        <div class="detail-text detail-description-full"><%= molba.description %></div>
      </div>

      <div class="detail-section">
        <h3>Документи</h3>
        <div class="doc-actions">
          <% if (molba.urlPath) { %>
            <a href="/dashboard/molba/<%= molba.molbaId %>/document/student" class="btn btn-small">Симни приложен документ</a>
          <% } else { %>
            <p class="subtitle">Нема приложен документ за оваа молба.</p>
          <% } %>

          <% if (molba.arhivaPdfPath) { %>
            <a href="/dashboard/molba/<%= molba.molbaId %>/document/archive" class="btn btn-small">Преглед/симни генериран PDF</a>
          <% } %>
        </div>
      </div>

      <% if (canArchiveNumber) { %>
        <div class="admin-action-card">
          <h3>Архивирање</h3>

          <% if (molba.arhivskiBroj) { %>
            <p class="subtitle">Архивскиот број е веќе внесен и молбата е проследена за обработка.</p>
          <% } else { %>
            <form action="/dashboard/molba/<%= molba.molbaId %>/archive-number" method="POST">
              <div class="form-group">
                <label for="arhivskiBroj">Архивски број</label>
                <input id="arhivskiBroj" name="arhivskiBroj" type="text" maxlength="100" placeholder="Пр. ARH-2026-001" required>
              </div>
              <div class="form-actions">
                <button type="submit" class="btn btn-admin">Зачувај архивски број</button>
              </div>
            </form>
          <% } %>
        </div>
      <% } %>


      <% if (molba.feedback) { %>
        <div class="detail-section feedback-section <%= molba.status === 'Одбиена' ? 'feedback-rejected' : 'feedback-approved' %>">
          <h3><%= molba.status === 'Одбиена' ? 'Причина за одбивање' : 'Повратна информација' %></h3>
          <p class="detail-text"><%= molba.feedback %></p>
        </div>
      <% } %>

      <% if (canManage) { %>
        <div class="admin-action-card">
          <h3>Обработка на молба</h3>
          <form action="/dashboard/molba/<%= molba.molbaId %>/status" method="POST">
            <div class="form-group">
              <label for="status">Нов статус</label>
              <select id="status" name="status" class="form-select" required>
                <option value="Во процес" <%= molba.status === 'Во процес' ? 'selected' : '' %>>Во процес</option>
                <option value="Одобрена" <%= molba.status === 'Одобрена' ? 'selected' : '' %>>Одобрена</option>
                <option value="Одбиена" <%= molba.status === 'Одбиена' ? 'selected' : '' %>>Одбиена</option>
              </select>
            </div>
            <div class="form-group">
              <label for="feedback">Повратна информација</label>
              <textarea id="feedback" name="feedback" rows="4" placeholder="Внесете причина или забелешка..."><%= molba.feedback || '' %></textarea>
            </div>
            <div class="form-actions">
              <a href="/dashboard" class="btn btn-secondary">← Назад</a>
              <button type="submit" class="btn btn-admin">Зачувај одлука</button>
            </div>
          </form>
        </div>
      <% } %>

      <% if (canGenerateMolbaPdf) { %>
        <div class="admin-action-card">
          <h3>Генерирање на PDF</h3>
          <p class="subtitle">Генерирај PDF и пратај email на студентот.</p>
          <form action="/dashboard/molba/<%= molba.molbaId %>/generate-molba-pdf" method="POST">
            <div class="form-actions">
              <button type="submit" class="btn btn-admin">Генерирај PDF</button>
            </div>
          </form>
        </div>
      <% } %>

      <% if (!canManage && !canGenerateMolbaPdf) { %>
        <div class="detail-actions">
          <a href="/dashboard" class="btn btn-secondary">← Назад кон Dashboard</a>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
