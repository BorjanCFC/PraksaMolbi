<div class="animated-bg"></div>
<div class="header-wrap">
  <div class="header-top"></div>
  <header class="header">
    <div class="header-container">
      <a href="/dashboard" class="logo">
        <img src="/images/logo-feit-header.png" alt="УКИМ — ФЕИТ" class="header-logo-wide">
      </a>
      <nav>
        <% if (viewer) { %>
          <% const roleLabelFallbackMap = {
            admin: 'Админ - ФЕИТ',
            studentska_sluzhba: 'Студентска Служба - ФЕИТ',
            prodekan: 'Продекан - ФЕИТ',
            arhiva: 'Архива - ФЕИТ',
            student: 'Студент'
          }; %>
          <% const displayRoleLabel = (viewer.role && roleLabelFallbackMap[viewer.role]) || ((typeof getRoleLabel === 'function' && viewer.role) ? getRoleLabel(viewer.role) : viewer.roleLabel); %>
          <% const isStaffRole = viewer.role === 'arhiva' || viewer.role === 'prodekan' || viewer.role === 'admin' || viewer.role === 'studentska_sluzhba'; %>
          <span class="nav-user">
            <% if (isStaffRole) { %>
              <%= displayRoleLabel %>
            <% } else { %>
              <%= convertNameToCyrillic(viewer.ime) %> <%= convertNameToCyrillic(viewer.prezime) %>
              <% if (viewer.brIndeks) { %>
                (<%= viewer.brIndeks %>)
              <% } %>
              - <%= displayRoleLabel %>
            <% } %>
          </span>
        <% } %>

        <a href="/logout" class="nav-link btn-logout">Одјава</a>
      </nav>
    </div>
  </header>
</div>
